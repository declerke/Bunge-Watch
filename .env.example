# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=bungewatch
POSTGRES_PASSWORD=bungewatch
POSTGRES_DB=bungewatch
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── Airflow ──────────────────────────────────────────────────────────────────
# Generate fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here
AIRFLOW_ADMIN_PASSWORD=admin

# ─── Anthropic (OPTIONAL — not required) ─────────────────────────────────────
# Summaries and foreign-law matching use free local NLP (spaCy).
# Leave blank — the pipeline runs fully without an API key.
ANTHROPIC_API_KEY=

# ─── Scraping ─────────────────────────────────────────────────────────────────
KENYALAW_BASE_URL=https://kenyalaw.org/kl/index.php
PARLIAMENT_BASE_URL=https://www.parliament.go.ke
SCRAPE_YEARS=2024,2025,2026
REQUEST_DELAY_SECONDS=2

# ─── Storage ──────────────────────────────────────────────────────────────────
PDF_STORAGE_PATH=/opt/airflow/data/pdfs
